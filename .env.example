# Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (gemini-2.0-flash is fast and cheap; use gemini-1.5-pro for harder tasks)
GEMINI_MODEL=gemini-2.0-flash

# Working directory scope (agent will only touch files inside this path)
AGENT_WORK_DIR=.

# Max command execution timeout in milliseconds
COMMAND_TIMEOUT_MS=30000

# Hard upper bound for any command timeout
MAX_COMMAND_TIMEOUT_MS=30000

# Max command output size in bytes
COMMAND_MAX_OUTPUT_BYTES=262144

# Max reasoning iterations for the agent loop
MAX_ITERATIONS=12

# Stop after too many failed or malformed AI turns
MAX_CONSECUTIVE_FAILURES=3
MAX_INVALID_AI_RESPONSES=3

# Max executable actions per task
MAX_STEPS_PER_TASK=25

# File safety limits
MAX_FILE_READ_BYTES=524288
MAX_FILE_EDIT_BYTES=524288

# Runtime memory and persisted context limits
MAX_MEMORY_BYTES=536870912
MAX_CONTEXT_FILE_BYTES=1048576

# Git and HTTP tool limits
GIT_TIMEOUT_MS=15000
HTTP_TIMEOUT_MS=10000
HTTP_MAX_RESPONSE_BYTES=262144
HTTP_ALLOWED_DOMAINS=api.github.com,localhost,127.0.0.1

# Enable debug logging (true/false)
DEBUG=false
